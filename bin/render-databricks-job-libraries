#!/usr/bin/env bash
# INTERFACE INTERNA
# Este script por profile permanece por compatibilidade e uso interno.
# A interface recomendada para desenvolvedores e times de entrega e --workload.
# Nao editar arquitetura manualmente a partir daqui.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME=""
PROFILE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env)
      ENV_NAME="${2:-}"
      shift 2
      ;;
    --profile)
      PROFILE_NAME="${2:-}"
      shift 2
      ;;
    *)
      echo "[ERROR] Uso: bin/render-databricks-job-libraries --env <dev|hml|prd> --profile <data|api|ml|rag>"
      exit 1
      ;;
  esac
done

if [[ -z "$ENV_NAME" || -z "$PROFILE_NAME" ]]; then
  echo "[ERROR] Uso: bin/render-databricks-job-libraries --env <dev|hml|prd> --profile <data|api|ml|rag>"
  exit 1
fi

./bin/render-databricks-runtime-spec --env "$ENV_NAME" --profile "$PROFILE_NAME" >/dev/null

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import json

env_name = "${ENV_NAME}"
profile_name = "${PROFILE_NAME}"

spec_file = Path(".state/databricks") / f"runtime-spec-{env_name}-{profile_name}.json"
spec = json.loads(spec_file.read_text(encoding="utf-8"))

libraries = [{"whl": spec["libraries"]["whl"]}]
libraries.extend({"pypi": item} for item in spec["libraries"]["pypi"])

out_file = Path(".state/databricks") / f"job-libraries-{env_name}-{profile_name}.json"
out_file.write_text(json.dumps(libraries, indent=2, ensure_ascii=False), encoding="utf-8")

print(f"[OK] Job libraries gerado: {out_file}")
print(json.dumps(libraries, indent=2, ensure_ascii=False))
PY
