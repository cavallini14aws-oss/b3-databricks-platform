#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

PORT="${PDF_RAG_PORT:-8010}"
HOST="${PDF_RAG_HOST:-127.0.0.1}"

echo "[INFO] Rebuilding vectorstore"
rm -rf pipelines/examples/pdf_rag_lab/backend/vectorstore/*
python pipelines/examples/pdf_rag_lab/backend/setup_docs.py

PIDS="$(lsof -ti tcp:${PORT} || true)"
if [[ -n "$PIDS" ]]; then
  echo "[INFO] Killing processes on port ${PORT}: $PIDS"
  kill -9 $PIDS
  sleep 1
else
  echo "[INFO] No running process found on port ${PORT}"
fi

echo "[INFO] Starting PDF RAG Lab on ${HOST}:${PORT}"
exec python -m uvicorn pipelines.examples.pdf_rag_lab.backend.main:app \
  --host "${HOST}" \
  --port "${PORT}" \
  --reload
