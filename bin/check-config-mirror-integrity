#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

pairs=(
  "config/workloads_registry.yml:data_platform/resources/config/workloads_registry.yml"
  "config/official_environment_contract.yml:data_platform/resources/config/official_environment_contract.yml"
  "config/official_operational_integration_contract.yml:data_platform/resources/config/official_operational_integration_contract.yml"
)

errors=()

for pair in "${pairs[@]}"; do
  src="${pair%%:*}"
  dst="${pair##*:}"

  if [[ ! -f "$src" ]]; then
    errors+=("source of truth ausente: $src")
    continue
  fi

  if [[ ! -f "$dst" ]]; then
    errors+=("mirror empacotado ausente: $dst")
    continue
  fi

  if ! diff -q "$src" "$dst" >/dev/null 2>&1; then
    errors+=("mirror divergente: $src != $dst")
  fi
done

if ((${#errors[@]} > 0)); then
  echo "[ERROR] config mirror integrity check falhou"
  for err in "${errors[@]}"; do
    echo " - $err"
  done
  exit 1
fi

echo "[OK] config mirror integrity check aprovado"
