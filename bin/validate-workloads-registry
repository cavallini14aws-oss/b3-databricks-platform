#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

python - <<'PY'
from pathlib import Path
import sys
import yaml

registry = Path("config/workloads_registry.yml")
if not registry.exists():
    print("[ERROR] Registry ausente: config/workloads_registry.yml")
    sys.exit(1)

data = yaml.safe_load(registry.read_text(encoding="utf-8")) or {}
errors = []

if data.get("version") != 1:
    errors.append("version deve ser 1")

workloads = data.get("workloads")
if not isinstance(workloads, list) or not workloads:
    errors.append("workloads ausente ou invalido")
else:
    names = set()
    for item in workloads:
        for field in ("name", "type", "entrypoint"):
            if not item.get(field):
                errors.append(f"campo ausente em workload: {field}")

        wtype = item.get("type")
        if wtype not in {"data", "api", "ml", "rag"}:
            errors.append(f"type invalido: {wtype}")

        if wtype == "rag":
            variant = item.get("variant")
            if variant not in {"standard", "mlflow"}:
                errors.append(f"variant invalido para rag: {variant}")

        name = item.get("name")
        if name in names:
            errors.append(f"nome duplicado: {name}")
        if name:
            names.add(name)

        entrypoint = item.get("entrypoint")
        if entrypoint:
            path = Path(entrypoint)
            if not path.exists():
                errors.append(f"entrypoint inexistente: {entrypoint}")
            elif path.is_dir():
                errors.append(f"entrypoint aponta para diretorio: {entrypoint}")
            elif path.suffix != ".py":
                errors.append(f"entrypoint deve apontar para arquivo .py: {entrypoint}")

if errors:
    for e in errors:
        print(f"[ERROR] {e}")
    sys.exit(1)

print("[OK] Workloads registry validado com integridade fisica dos entrypoints")
PY
