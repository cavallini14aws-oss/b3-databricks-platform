#!/usr/bin/env bash
set -euo pipefail

if [ -n "${ZSH_VERSION:-}" ]; then
  SCRIPT_PATH="${(%):-%N}"
  CALLED_DIRECTLY=0
elif [ -n "${BASH_VERSION:-}" ]; then
  SCRIPT_PATH="${BASH_SOURCE[0]}"
  if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    CALLED_DIRECTLY=1
  else
    CALLED_DIRECTLY=0
  fi
else
  SCRIPT_PATH="$0"
  CALLED_DIRECTLY=0
fi

if [[ "${CALLED_DIRECTLY}" -eq 1 ]]; then
  echo "[ERROR] Use: source bin/use-databricks-official <dev|hml> [profile] [serving-endpoint]"
  exit 1
fi

ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
PROFILE_NAME_ARG="${2:-}"
SERVING_ENDPOINT_ARG="${3:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Use: source bin/use-databricks-official <dev|hml> [profile] [serving-endpoint]"
  return 1
fi

case "$ENV_NAME" in
  dev|hml) ;;
  prd)
    echo "[ERROR] Produção não pode usar bin/use-databricks-official"
    echo "[INFO] Use: source bin/use-databricks-official-m2m prd"
    return 1
    ;;
  *)
    echo "[ERROR] Ambiente inválido: $ENV_NAME"
    return 1
    ;;
esac

if ! command -v databricks >/dev/null 2>&1; then
  echo "[ERROR] Databricks CLI não encontrado"
  return 1
fi

if [[ ! -f ".databricks.official.endpoints.yml" ]]; then
  echo "[ERROR] Arquivo .databricks.official.endpoints.yml não encontrado"
  return 1
fi

PROFILE_FROM_MAP="$(python3 - <<PY
import yaml
from pathlib import Path
data = yaml.safe_load(Path(".databricks.official.endpoints.yml").read_text(encoding="utf-8"))
print(data.get("$ENV_NAME", {}).get("profile", ""))
PY
)"

HOST_FROM_MAP="$(python3 - <<PY
import yaml
from pathlib import Path
data = yaml.safe_load(Path(".databricks.official.endpoints.yml").read_text(encoding="utf-8"))
print(data.get("$ENV_NAME", {}).get("host", ""))
PY
)"

ENDPOINT_FROM_MAP="$(python3 - <<PY
import yaml
from pathlib import Path
data = yaml.safe_load(Path(".databricks.official.endpoints.yml").read_text(encoding="utf-8"))
print(data.get("$ENV_NAME", {}).get("serving_endpoint", ""))
PY
)"

PROFILE_NAME="${PROFILE_NAME_ARG:-$PROFILE_FROM_MAP}"
HOST="${HOST_FROM_MAP:-}"
SERVING_ENDPOINT="${SERVING_ENDPOINT_ARG:-$ENDPOINT_FROM_MAP}"

if [[ -z "$PROFILE_NAME" || "$PROFILE_NAME" == "TO_BE_DEFINED" ]]; then
  echo "[ERROR] profile inválido para env=$ENV_NAME"
  return 1
fi

if [[ -z "$HOST" || "$HOST" == "TO_BE_DEFINED" ]]; then
  echo "[ERROR] host inválido para env=$ENV_NAME em .databricks.official.endpoints.yml"
  return 1
fi

if [[ -z "$SERVING_ENDPOINT" || "$SERVING_ENDPOINT" == "TO_BE_DEFINED" ]]; then
  echo "[ERROR] serving endpoint inválido para env=$ENV_NAME"
  return 1
fi

AUTH_ENV_JSON="$(databricks auth env --profile "$PROFILE_NAME" --output json)" || {
  echo "[ERROR] Falha ao resolver auth via profile=$PROFILE_NAME"
  echo "[FIX] Rode: databricks auth login $HOST --profile $PROFILE_NAME"
  return 1
}

TOKEN="$(printf '%s' "$AUTH_ENV_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("env",{}).get("DATABRICKS_TOKEN",""))')"

if [[ -z "$TOKEN" ]]; then
  echo "[ERROR] Não foi possível resolver DATABRICKS_TOKEN via databricks auth env"
  echo "[FIX] Rode: databricks auth login $HOST --profile $PROFILE_NAME"
  return 1
fi

export DATABRICKS_HOST="$HOST"
export DATABRICKS_TOKEN="$TOKEN"
export DATABRICKS_SERVING_ENDPOINT="$SERVING_ENDPOINT"
export DATABRICKS_CONFIG_PROFILE="$PROFILE_NAME"
export DATABRICKS_ENV="$ENV_NAME"
export LLM_PROVIDER="databricks"

echo "[INFO] Databricks official mode loaded"
echo "[INFO] env=$DATABRICKS_ENV"
echo "[INFO] profile=$DATABRICKS_CONFIG_PROFILE"
echo "[INFO] host=$DATABRICKS_HOST"
echo "[INFO] endpoint=$DATABRICKS_SERVING_ENDPOINT"
echo "[INFO] provider=$LLM_PROVIDER"
echo "[INFO] token=[REDACTED]"
