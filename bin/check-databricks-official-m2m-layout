#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

required_files=(
  ".databricks.official.endpoints.yml"
  ".secrets.databricks.oauth.example"
  "bin/use-databricks-official-m2m"
  "bin/dbx-rag-smoke-official"
)

for file in "${required_files[@]}"; do
  if [[ -f "$file" ]]; then
    echo "[OK] Found: $file"
  else
    echo "[ERROR] Missing: $file"
    exit 1
  fi
done

python3 - <<'PY'
from pathlib import Path
import yaml
import sys

path = Path(".databricks.official.endpoints.yml")
data = yaml.safe_load(path.read_text(encoding="utf-8"))

required_envs = ["dev", "hml", "prd"]
required_keys = ["profile", "serving_endpoint"]

ok = True
for env_name in required_envs:
    if env_name not in data:
        print(f"[ERROR] Missing env '{env_name}' in {path}")
        ok = False
        continue
    for key in required_keys:
        if key not in data[env_name]:
            print(f"[ERROR] Missing key '{env_name}.{key}' in {path}")
            ok = False

if not ok:
    sys.exit(1)

print("[INFO] Databricks official M2M layout validation passed")
PY
