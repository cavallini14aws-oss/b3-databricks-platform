#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

echo "[INFO] Running collection summary engine"
./bin/test-pdf-rag-collection-summary
echo

echo "[INFO] Running dynamic API suite"
./bin/test-pdf-rag-dynamic-suite
