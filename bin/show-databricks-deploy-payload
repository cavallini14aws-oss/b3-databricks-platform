#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/show-databricks-deploy-payload <dev|hml|prd>"
  exit 1
fi

FILE=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

if [[ ! -f "$FILE" ]]; then
  echo "[ERROR] Deploy payload ausente: $FILE"
  exit 1
fi

cat "$FILE"
