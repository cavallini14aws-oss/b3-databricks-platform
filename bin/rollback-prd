#!/usr/bin/env python3
import json
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

from data_platform.core.release_state import load_release_state, save_release_state, utc_now_iso


def run(cmd):
    result = subprocess.run(cmd, text=True, capture_output=True)
    if result.stdout:
        print(result.stdout, flush=True)
    if result.stderr:
        print(result.stderr, flush=True)
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    return result.stdout.strip()


def main():
    profile = sys.argv[1] if len(sys.argv) > 1 else ""

    state = load_release_state()
    prd_state = state["prd"]

    rollback_candidate = prd_state.get("rollback_candidate")
    current_version = prd_state.get("current_version")

    if not rollback_candidate:
        print("[BLOCK] rollback_candidate ausente para prd")
        raise SystemExit(1)

    report = {
        "env": "prd",
        "current_version": current_version,
        "rollback_candidate": rollback_candidate,
        "rolled_back_at": utc_now_iso(),
    }

    Path("artifacts").mkdir(exist_ok=True)
    Path("artifacts/rollback_prd_report.json").write_text(
        json.dumps(report, indent=2, ensure_ascii=False),
        encoding="utf-8",
    )

    prd_state["current_version"] = rollback_candidate
    prd_state["previous_version"] = current_version
    prd_state["last_promoted_at"] = utc_now_iso()
    prd_state["last_smoke_status"] = "required_after_rollback"
    prd_state["rollback_candidate"] = current_version

    save_release_state(state)

    smoke_cmd = ["./bin/post-deploy-smoke", "prd"]
    if profile:
        smoke_cmd.append(profile)

    print(json.dumps(report, indent=2, ensure_ascii=False))
    print("[INFO] rollback lógico aplicado. Rodando smoke pós-rollback...")
    run(smoke_cmd)


if __name__ == "__main__":
    main()
