#!/usr/bin/env bash
set -euo pipefail

required_files=(
  "databricks/pdf_rag/config/pdf_rag_tables.yml"
  "databricks/pdf_rag/config/pdf_rag_runtime.yml"
  "databricks/pdf_rag/config/pdf_rag_vector_search.yml"
  "databricks/pdf_rag/config/pdf_rag_foundation_models.yml"
  "databricks/pdf_rag/config/pdf_rag_ai_gateway.yml"
  "databricks/pdf_rag/config/pdf_rag_custom_serving.yml"
  "databricks/pdf_rag/sql/create_pdf_rag_tables.sql"
  "databricks/pdf_rag/src/vector_index_bootstrap.py"
  "databricks/pdf_rag/src/query_vector_index.py"
  "databricks/pdf_rag/src/foundation_model_client.py"
  "databricks/pdf_rag/src/smoke_foundation_model.py"
  "databricks/pdf_rag/src/ai_gateway_config_summary.py"
  "databricks/pdf_rag/src/custom_pyfunc_model.py"
  "databricks/pdf_rag/src/register_custom_pyfunc_model.py"
  "databricks/pdf_rag/src/deploy_custom_serving_endpoint.py"
  "databricks/pdf_rag/src/smoke_custom_serving.py"
  "databricks/pdf_rag/notebooks/03_create_vector_index.py"
  "databricks/pdf_rag/notebooks/04_query_vector_index.py"
  "databricks/pdf_rag/notebooks/05_test_foundation_model.py"
  "databricks/pdf_rag/notebooks/06_batch_inference_ai_query.sql"
  "databricks/pdf_rag/notebooks/07_ai_gateway_enablement_check.py"
  "databricks/pdf_rag/notebooks/08_query_inference_tables.sql"
  "databricks/pdf_rag/notebooks/09_register_custom_pyfunc_model.py"
  "databricks/pdf_rag/notebooks/10_deploy_custom_serving_endpoint.py"
  "databricks/pdf_rag/notebooks/11_smoke_custom_serving.py"
  "docs/databricks/pdf_rag/AI_GATEWAY_ROADMAP.md"
  "docs/databricks/pdf_rag/CUSTOM_MODEL_SERVING_ROADMAP.md"
  "bin/check-databricks-pdf-rag-isolation"
)

for file in "${required_files[@]}"; do
  if [[ -f "$file" ]]; then
    echo "[OK] Found: $file"
  else
    echo "[ERROR] Missing: $file"
    exit 1
  fi
done

./bin/check-databricks-pdf-rag-isolation

echo "[OK] Databricks PDF RAG readiness baseline is present"
