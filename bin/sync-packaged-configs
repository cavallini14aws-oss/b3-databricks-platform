#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC_DIR="${ROOT_DIR}/config"
DST_DIR="${ROOT_DIR}/data_platform/resources/config"

test -d "${SRC_DIR}"
mkdir -p "${DST_DIR}"

rsync -a --delete \
  --exclude '__pycache__/' \
  --exclude '.DS_Store' \
  "${SRC_DIR}/" "${DST_DIR}/"

echo "[OK] Config empacotada sincronizada."
