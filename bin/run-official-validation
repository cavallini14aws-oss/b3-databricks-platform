#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Use: bin/run-official-validation <dev|hml|prd>"
  exit 1
fi

case "${ENV_NAME}" in
  dev|hml|prd) ;;
  *)
    echo "[ERROR] Ambiente invalido: ${ENV_NAME}"
    exit 1
    ;;
esac

case "${ENV_NAME}" in
  hml|prd)
    if [[ -n "${DATABRICKS_CONFIG_PROFILE:-}" ]]; then
      echo "[ERRO] ${ENV_NAME} nao aceita DATABRICKS_CONFIG_PROFILE. Use oauth-m2m."
      exit 1
    fi

    if [[ "${DATABRICKS_AUTH_TYPE:-}" != "oauth-m2m" ]]; then
      echo "[ERRO] ${ENV_NAME} exige DATABRICKS_AUTH_TYPE=oauth-m2m."
      exit 1
    fi

    for required_var in DATABRICKS_HOST DATABRICKS_CLIENT_ID DATABRICKS_CLIENT_SECRET; do
      if [[ -z "${!required_var:-}" ]]; then
        echo "[ERRO] ${ENV_NAME} exige $required_var."
        exit 1
      fi
    done
    ;;
esac

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

./bin/bootstrap-official-env "$ENV_NAME"

case "$ENV_NAME" in
  dev)
    ./bin/check-live-auth dev
    ./bin/dbx-rag-smoke-official dev
    ;;
  hml)
    ./bin/hml-preflight
    ./bin/check-live-auth hml
    ./bin/dbx-rag-smoke-official hml-m2m
    ;;
  prd)
    ./bin/prd-preflight
    ./bin/check-live-auth prd
    ./bin/dbx-rag-smoke-official prd-m2m
    ;;
esac

echo "[OK] validação oficial concluída para env=${ENV_NAME}"
