#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/dry-run-official-deploy <dev|hml|prd>"
  exit 1
fi

RELEASE_MANIFEST=".state/releases/official-release-manifest-${ENV_NAME}.yml"
FINAL_RELEASE=".state/releases/final-official-release-${ENV_NAME}.yml"
DEPLOY_PAYLOAD=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

for file in "$RELEASE_MANIFEST" "$FINAL_RELEASE" "$DEPLOY_PAYLOAD"; do
  if [[ ! -f "$file" ]]; then
    echo "[ERROR] arquivo obrigatorio ausente: $file"
    exit 1
  fi
done

RUN_DIR=".state/dry-run/${ENV_NAME}"
mkdir -p "$RUN_DIR"

TRACE_FILE="${RUN_DIR}/trace.log"
RESULT_FILE="${RUN_DIR}/result.json"
VALIDATE_LOG="${RUN_DIR}/bundle_validate.log"
PLAN_LOG="${RUN_DIR}/bundle_plan.log"
SUMMARY_LOG="${RUN_DIR}/bundle_summary.log"

: > "$TRACE_FILE"

python - <<PY
from pathlib import Path
import json
import sys
import yaml

env_name = "${ENV_NAME}"

release_manifest = yaml.safe_load(Path("${RELEASE_MANIFEST}").read_text(encoding="utf-8"))
final_release = yaml.safe_load(Path("${FINAL_RELEASE}").read_text(encoding="utf-8"))
deploy_payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

errors = []

for key in ["release_version", "artifact_wheel", "profiles", "ready"]:
    if key not in release_manifest:
        errors.append(f"official release manifest sem campo obrigatorio: {key}")

for key in ["release_version", "artifact_wheel", "profiles", "ready"]:
    if key not in final_release:
        errors.append(f"final release sem campo obrigatorio: {key}")

for key in ["deploy_version", "source_release_version", "artifact_wheel", "bundle_targets", "jobs", "job_count", "profile_variants"]:
    if key not in deploy_payload:
        errors.append(f"deploy payload sem campo obrigatorio: {key}")

if errors:
    print("[ERROR] dry-run falhou para env=" + env_name)
    for err in errors:
        print(" - " + err)
    sys.exit(1)
PY

echo "[INFO] validacao declarativa ok para env=${ENV_NAME}" | tee -a "$TRACE_FILE"

BUNDLE_VALIDATE_STATUS="skipped"
BUNDLE_PLAN_STATUS="skipped"
BUNDLE_SUMMARY_STATUS="skipped"

if command -v databricks >/dev/null 2>&1; then
  if databricks bundle validate -t "$ENV_NAME" >"$VALIDATE_LOG" 2>&1; then
    BUNDLE_VALIDATE_STATUS="ok"
  else
    BUNDLE_VALIDATE_STATUS="failed"
    cat "$VALIDATE_LOG"
    exit 1
  fi

  if [[ "${DATABRICKS_DRY_RUN_REMOTE:-0}" == "1" ]]; then
    if databricks bundle plan -t "$ENV_NAME" >"$PLAN_LOG" 2>&1; then
      BUNDLE_PLAN_STATUS="ok"
    else
      BUNDLE_PLAN_STATUS="failed"
      cat "$PLAN_LOG"
      exit 1
    fi

    if databricks bundle summary -t "$ENV_NAME" --force-pull >"$SUMMARY_LOG" 2>&1; then
      BUNDLE_SUMMARY_STATUS="ok"
    else
      BUNDLE_SUMMARY_STATUS="failed"
      cat "$SUMMARY_LOG"
      exit 1
    fi
  fi
fi

python - <<PY
from pathlib import Path
import json
import yaml

env_name = "${ENV_NAME}"
final_release = yaml.safe_load(Path("${FINAL_RELEASE}").read_text(encoding="utf-8"))
deploy_payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

summary = {
    "env": env_name,
    "dry_run_scope": "declarative_plus_optional_bundle_cli",
    "release_version": final_release["release_version"],
    "artifact_wheel": final_release["artifact_wheel"],
    "profiles": [p["profile"] for p in final_release["profiles"]],
    "profile_variants": deploy_payload["profile_variants"],
    "job_count": len(deploy_payload["jobs"]),
    "bundle_validate_status": BUNDLE_VALIDATE_STATUS_PLACEHOLDER,
    "bundle_plan_status": BUNDLE_PLAN_STATUS_PLACEHOLDER,
    "bundle_summary_status": BUNDLE_SUMMARY_STATUS_PLACEHOLDER,
}
Path("${RESULT_FILE}").write_text(
    json.dumps(summary, indent=2, ensure_ascii=False)
    .replace("BUNDLE_VALIDATE_STATUS_PLACEHOLDER", "${BUNDLE_VALIDATE_STATUS}")
    .replace("BUNDLE_PLAN_STATUS_PLACEHOLDER", "${BUNDLE_PLAN_STATUS}")
    .replace("BUNDLE_SUMMARY_STATUS_PLACEHOLDER", "${BUNDLE_SUMMARY_STATUS}"),
    encoding="utf-8",
)
print("[OK] dry-run oficial endurecido")
PY
