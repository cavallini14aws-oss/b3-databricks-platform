#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME=""
PROFILE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env)
      ENV_NAME="${2:-}"
      shift 2
      ;;
    --profile)
      PROFILE_NAME="${2:-}"
      shift 2
      ;;
    *)
      echo "[ERROR] Uso: bin/render-databricks-job-spec --env <dev|hml|prd> --profile <data|api|ml|rag>"
      exit 1
      ;;
  esac
done

if [[ -z "$ENV_NAME" || -z "$PROFILE_NAME" ]]; then
  echo "[ERROR] Uso: bin/render-databricks-job-spec --env <dev|hml|prd> --profile <data|api|ml|rag>"
  exit 1
fi

./bin/render-databricks-job-libraries --env "$ENV_NAME" --profile "$PROFILE_NAME" >/dev/null
./bin/render-databricks-runtime-spec --env "$ENV_NAME" --profile "$PROFILE_NAME" >/dev/null

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import json
from datetime import datetime, timezone

env_name = "${ENV_NAME}"
profile_name = "${PROFILE_NAME}"

spec_file = Path(".state/databricks") / f"runtime-spec-{env_name}-{profile_name}.json"
libs_file = Path(".state/databricks") / f"job-libraries-{env_name}-{profile_name}.json"

runtime_spec = json.loads(spec_file.read_text(encoding="utf-8"))
libraries = json.loads(libs_file.read_text(encoding="utf-8"))

job_spec = {
    "generated_at_utc": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "name": f"b3-{env_name}-{profile_name}-job",
    "env": env_name,
    "profile": profile_name,
    "artifact_wheel": runtime_spec["artifact_wheel"],
    "libraries": libraries,
    "parameters": {
        "ENV": env_name,
        "PROFILE": profile_name,
        "ARTIFACT_WHEEL": runtime_spec["artifact_wheel"],
    },
    "mode": "databricks-job-spec",
}

out_file = Path(".state/databricks") / f"job-spec-{env_name}-{profile_name}.json"
out_file.write_text(json.dumps(job_spec, indent=2, ensure_ascii=False), encoding="utf-8")

print(f"[OK] Job spec gerado: {out_file}")
print(json.dumps(job_spec, indent=2, ensure_ascii=False))
PY
