#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/bootstrap-official-release-state <dev|hml|prd>"
  exit 1
fi

case "$ENV_NAME" in
  dev|hml|prd) ;;
  *)
    echo "[ERROR] Ambiente invalido: $ENV_NAME"
    exit 1
    ;;
esac

PROFILES=(data api ml rag)

echo "[INFO] bootstrap official release state env=${ENV_NAME}"

for profile in "${PROFILES[@]}"; do
  echo "[INFO] renderizando profile=${profile}"
  ./bin/render-official-bundle-target --env "$ENV_NAME" --profile "$profile" >/dev/null
  ./bin/check-official-readiness-by-profile "$ENV_NAME" "$profile" >/dev/null
done

./bin/render-official-readiness-index >/dev/null

echo "[OK] bootstrap official release state concluido para env=${ENV_NAME}"
