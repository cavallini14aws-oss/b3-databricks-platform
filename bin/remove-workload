#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

NAME="${1:-}"

if [[ -z "$NAME" ]]; then
  echo "[ERROR] Uso: bin/remove-workload <nome>"
  exit 1
fi

REGISTRY_FILE="config/workloads_registry.yml"

if [[ ! -f "$REGISTRY_FILE" ]]; then
  echo "[ERROR] Registry ausente: $REGISTRY_FILE"
  exit 1
fi

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import sys
import yaml

registry_file = Path("${REGISTRY_FILE}")
name = "${NAME}"

data = yaml.safe_load(registry_file.read_text(encoding="utf-8"))
workloads = data.get("workloads", [])
new_workloads = [w for w in workloads if w.get("name") != name]

if len(new_workloads) == len(workloads):
    print(f"[ERROR] workload nao encontrado: {name}")
    sys.exit(1)

data["workloads"] = new_workloads
registry_file.write_text(yaml.safe_dump(data, allow_unicode=True, sort_keys=False), encoding="utf-8")
print(f"[OK] workload removido do registry: {name}")
PY

./bin/sync-workloads-registry >/dev/null
./bin/validate-workloads-registry >/dev/null
./bin/render-all-workload-manifests >/dev/null

echo "[OK] workload removido e arquitetura derivada atualizada"
