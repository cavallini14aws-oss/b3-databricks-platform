#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/check-official-release-manifest <dev|hml|prd>"
  exit 1
fi

MANIFEST_FILE=".state/releases/official-release-manifest-${ENV_NAME}.yml"

if [[ ! -f "$MANIFEST_FILE" ]]; then
  echo "[ERROR] Manifest ausente: $MANIFEST_FILE"
  exit 1
fi

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import sys
import yaml

manifest_file = Path("${MANIFEST_FILE}")
data = yaml.safe_load(manifest_file.read_text(encoding="utf-8"))

if not data.get("artifact_wheel"):
    print("[ERROR] artifact_wheel ausente")
    sys.exit(1)

if "profiles" not in data or not isinstance(data["profiles"], list):
    print("[ERROR] profiles ausente ou invalido")
    sys.exit(1)

not_ready = [entry["profile"] for entry in data["profiles"] if not entry.get("ready")]

if not_ready:
    print("[ERROR] Profiles nao prontos: " + ", ".join(not_ready))
    sys.exit(1)

print(f"[OK] Official release manifest validado: {manifest_file}")
PY
