#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"
PROFILE_NAME="${2:-}"

if [[ -z "$ENV_NAME" || -z "$PROFILE_NAME" ]]; then
  echo "[ERROR] Uso: bin/check-official-bundle-target <dev|hml|prd> <data|api|ml|rag>"
  exit 1
fi

TARGET_FILE=".state/databricks/bundle-target-${ENV_NAME}-${PROFILE_NAME}.yml"

if [[ "$ENV_NAME" == "hml" || "$ENV_NAME" == "prd" ]]; then
  if [[ ! -f "$TARGET_FILE" ]]; then
    echo "[ERROR] ${ENV_NAME} exige official bundle target renderizado: $TARGET_FILE"
    exit 1
  fi
fi

echo "[OK] Official bundle target validado para env=${ENV_NAME} profile=${PROFILE_NAME}"
