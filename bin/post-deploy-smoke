#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-dev}"
PROFILE_NAME="${2:-}"

run_job() {
  local job_name="$1"
  if [[ -z "${PROFILE_NAME}" ]]; then
    databricks bundle run --target "${ENV_NAME}" "${job_name}"
  else
    databricks bundle run --target "${ENV_NAME}" --profile "${PROFILE_NAME}" "${job_name}"
  fi
}

on_fail() {
  ./bin/update-smoke-status "${ENV_NAME}" failed || true
}
trap on_fail ERR

run_job mlops_drift_cycle
run_job mlops_postprod_cycle
run_job mlops_retraining_cycle
run_job mlops_operational_cycle

./bin/update-smoke-status "${ENV_NAME}" success
