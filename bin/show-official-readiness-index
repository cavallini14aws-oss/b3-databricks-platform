#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

INDEX_FILE=".state/official-readiness-index.json"

if [[ ! -f "$INDEX_FILE" ]]; then
  echo "[ERROR] Índice ausente: $INDEX_FILE"
  echo "[INFO] Gere antes com: ./bin/render-official-readiness-index"
  exit 1
fi

cat "$INDEX_FILE"
