#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PROFILE_NAME="${1:-}"

if [[ -z "$PROFILE_NAME" ]]; then
  echo "[ERROR] Use: bin/resolve-runtime-profile <data|api|ml|rag>"
  exit 1
fi

PROFILE_FILE="manifests/profiles/profile-${PROFILE_NAME}.yml"

if [[ ! -f "$PROFILE_FILE" ]]; then
  echo "[ERROR] Profile nao encontrado: $PROFILE_FILE"
  exit 1
fi

echo "$PROFILE_FILE"
