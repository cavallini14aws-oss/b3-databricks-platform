#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

if [[ -x "bin/check-runtime-env" ]]; then
  bin/check-runtime-env generic >/dev/null
fi

echo "[INFO] Databricks RAG generic smoke"
echo "[INFO] env=${DATABRICKS_ENV:-unset}"
echo "[INFO] host=${DATABRICKS_HOST:-unset}"
echo "[INFO] endpoint=${DATABRICKS_SERVING_ENDPOINT:-unset}"
echo "[INFO] provider=${LLM_PROVIDER:-unset}"

python -m pytest tests/databricks/test_foundation_model_client.py -q
rc=$?

echo "[RESULT] generic smoke exit_code=$rc"
exit $rc
