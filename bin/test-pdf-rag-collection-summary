#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

python - <<'PY'
import json
from pipelines.examples.pdf_rag_lab.backend.services.collection_summary import summarize_collection

result = summarize_collection()
print(json.dumps(result, ensure_ascii=False, indent=2))
PY
