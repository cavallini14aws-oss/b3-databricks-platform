#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "[INFO] Checking PDF RAG Lab Databricks readiness"

required_files=(
  "pipelines/examples/pdf_rag_lab/backend/services/config.py"
  "pipelines/examples/pdf_rag_lab/backend/services/llm_service.py"
  "pipelines/examples/pdf_rag_lab/backend/.env.example"
  "docs/examples/pdf_rag_lab/OPERATIONS.md"
  "bin/run-pdf-rag-lab-local"
  "bin/test-pdf-rag-lab-api"
  "bin/smoke-pdf-rag-lab"
)

for file in "${required_files[@]}"; do
  if [[ -f "$file" ]]; then
    echo "[OK] Found: $file"
  else
    echo "[ERROR] Missing: $file"
    exit 1
  fi
done

if grep -q 'LLM_PROVIDER' pipelines/examples/pdf_rag_lab/backend/services/config.py; then
  echo "[OK] LLM_PROVIDER found in config.py"
else
  echo "[ERROR] LLM_PROVIDER not found in config.py"
  exit 1
fi

if grep -q 'DATABRICKS_HOST' pipelines/examples/pdf_rag_lab/backend/services/llm_service.py; then
  echo "[OK] Databricks host handling found in llm_service.py"
else
  echo "[ERROR] Databricks host handling not found in llm_service.py"
  exit 1
fi

if grep -q 'DATABRICKS_SERVING_ENDPOINT' pipelines/examples/pdf_rag_lab/backend/.env.example; then
  echo "[OK] Databricks env contract found in .env.example"
else
  echo "[ERROR] Databricks env contract missing in .env.example"
  exit 1
fi

echo "[INFO] PDF RAG Lab Databricks readiness precheck passed"
