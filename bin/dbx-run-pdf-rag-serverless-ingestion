#!/usr/bin/env bash
set -euo pipefail

: "${DBX_PROFILE:?DBX_PROFILE nao definido}"
: "${DBX_WS_ROOT:?DBX_WS_ROOT nao definido}"

api_get() {
  local path="$1"
  databricks api get "$path" --profile "$DBX_PROFILE"
}

api_post() {
  local path="$1"
  local json_payload="$2"
  databricks api post "$path" --profile "$DBX_PROFILE" --json "$json_payload"
}

get_existing_job_id() {
  local job_name="$1"
  api_get /api/2.2/jobs/list | python3 - <<PY
import json, sys
target = """$job_name"""
data = json.load(sys.stdin)
for item in data.get("jobs", []):
    settings = item.get("settings", {})
    if settings.get("name") == target:
        print(item["job_id"])
        break
PY
}

create_job() {
  local job_name="$1"
  local notebook_path="$2"

  local payload
  payload="$(cat <<JSON
{
  "name": "$job_name",
  "tasks": [
    {
      "task_key": "task_${job_name//[^a-zA-Z0-9]/_}",
      "notebook_task": {
        "notebook_path": "$notebook_path",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 3600
    }
  ]
}
JSON
)"
  api_post /api/2.2/jobs/create "$payload" | python3 - <<'PY'
import json, sys
print(json.load(sys.stdin)["job_id"])
PY
}

ensure_job() {
  local job_name="$1"
  local notebook_path="$2"

  local job_id
  job_id="$(get_existing_job_id "$job_name" || true)"

  if [[ -n "${job_id:-}" ]]; then
    echo "$job_id"
    return
  fi

  create_job "$job_name" "$notebook_path"
}

run_job() {
  local job_id="$1"
  api_post /api/2.2/jobs/run-now "{\"job_id\": $job_id}" | python3 - <<'PY'
import json, sys
print(json.load(sys.stdin)["run_id"])
PY
}

wait_run() {
  local run_id="$1"

  while true; do
    local state
    state="$(api_get "/api/2.2/jobs/runs/get?run_id=$run_id" | python3 - <<'PY'
import json, sys
data = json.load(sys.stdin)
s = data["state"]
life_cycle = s["life_cycle_state"]
result = s.get("result_state", "")
print(f"{life_cycle}|{result}")
PY
)"
    echo "[INFO] run_id=$run_id state=$state"

    case "$state" in
      TERMINATED\|SUCCESS)
        return 0
        ;;
      TERMINATED\|FAILED|TERMINATED\|TIMEDOUT|INTERNAL_ERROR\|*|SKIPPED\|*|BLOCKED\|*)
        api_get "/api/2.2/jobs/runs/get?run_id=$run_id"
        return 1
        ;;
    esac

    sleep 10
  done
}

echo "[INFO] Ensuring job 01"
JOB_ID_01="$(ensure_job \
  "pdf-rag-01-inspect-documents" \
  "$DBX_WS_ROOT/databricks/pdf_rag/notebooks/01_inspect_documents")"
echo "[OK] JOB_ID_01=$JOB_ID_01"

echo "[INFO] Ensuring job 02"
JOB_ID_02="$(ensure_job \
  "pdf-rag-02-ingest-pages-and-chunks" \
  "$DBX_WS_ROOT/databricks/pdf_rag/notebooks/02_ingest_pages_and_chunks")"
echo "[OK] JOB_ID_02=$JOB_ID_02"

echo "[INFO] Running job 01"
RUN_ID_01="$(run_job "$JOB_ID_01")"
echo "[OK] RUN_ID_01=$RUN_ID_01"
wait_run "$RUN_ID_01"

echo "[INFO] Running job 02"
RUN_ID_02="$(run_job "$JOB_ID_02")"
echo "[OK] RUN_ID_02=$RUN_ID_02"
wait_run "$RUN_ID_02"

echo "[OK] Both serverless notebook jobs completed successfully"
