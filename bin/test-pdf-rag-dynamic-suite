#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

python - <<'PY'
import yaml
import requests

base_url = "http://127.0.0.1:8010"

with open("config/pdf_rag_document_catalog.yml", "r", encoding="utf-8") as f:
    data = yaml.safe_load(f)

docs = data["documents"]
doc_names = [doc["display_name"] for doc in docs]

print("[INFO] Health")
print(requests.get(f"{base_url}/health", timeout=10).text)
print()

if len(doc_names) >= 1:
    q = f"No documento '{doc_names[0]}', qual é o tema principal e como ele é introduzido?"
    print(f"[INFO] Single-document test: {doc_names[0]}")
    resp = requests.post(f"{base_url}/chat", json={"question": q}, timeout=30)
    print(resp.text)
    print()

if len(doc_names) >= 2:
    q = f"Compare os principais temas de '{doc_names[0]}' e '{doc_names[1]}'."
    print(f"[INFO] Compare test: {doc_names[0]} vs {doc_names[1]}")
    resp = requests.post(f"{base_url}/chat", json={"question": q}, timeout=30)
    print(resp.text)
    print()

print("[INFO] Collection summary")
resp = requests.post(
    f"{base_url}/chat",
    json={"question": "Quais são os principais temas tratados nos PDFs carregados?"},
    timeout=30,
)
print(resp.text)
print()
PY
