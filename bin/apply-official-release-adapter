#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
PROFILE="${BUNDLE_PROFILE:-}"
DEPLOY_USER="${BUNDLE_DEPLOY_USER:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/apply-official-release-adapter <dev|hml|prd>"
  exit 1
fi

if [[ -z "$PROFILE" ]]; then
  echo "[ERROR] BUNDLE_PROFILE nao definido"
  exit 1
fi

if [[ -z "$DEPLOY_USER" ]]; then
  echo "[ERROR] BUNDLE_DEPLOY_USER nao definido"
  exit 1
fi

FINAL_RELEASE=".state/releases/final-official-release-${ENV_NAME}.yml"
DEPLOY_PAYLOAD=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

mkdir -p .state/releases
mkdir -p .state/logs

RUN_TS="$(date -u +"%Y%m%dT%H%M%SZ")"
RUN_DIR=".state/logs/apply_${ENV_NAME}_${RUN_TS}"
mkdir -p "$RUN_DIR"

VALIDATE_LOG="${RUN_DIR}/bundle_validate.log"
DEPLOY_LOG="${RUN_DIR}/bundle_deploy.log"
TRACE_LOG="${RUN_DIR}/trace.log"
RESULT_JSON="${RUN_DIR}/result.json"

log() {
  printf '[INFO] %s\n' "$1" | tee -a "$TRACE_LOG"
}

fail() {
  printf '[ERROR] %s\n' "$1" | tee -a "$TRACE_LOG" >&2
  exit 1
}

run_step() {
  local step_name="$1"
  shift
  local start_ts end_ts duration

  start_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  log "START ${step_name}"

  if ! "$@"; then
    fail "Falha na etapa: ${step_name}"
  fi

  end_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  duration="$(python3 - <<PY
start = float("${start_ts}")
end = float("${end_ts}")
print(f"{end - start:.3f}s")
PY
)"
  log "END ${step_name} duration=${duration}"
}

log "run_dir=${RUN_DIR}"
log "env=${ENV_NAME}"
log "profile=${PROFILE}"

run_step "bootstrap_official_release_state" ./bin/bootstrap-official-release-state "$ENV_NAME"
run_step "render_official_release_manifest" ./bin/render-official-release-manifest "$ENV_NAME"
run_step "apply_final_official_release" ./bin/apply-final-official-release "$ENV_NAME"
run_step "render_databricks_deploy_payload" ./bin/render-databricks-deploy-payload "$ENV_NAME"

[[ -f "$FINAL_RELEASE" ]] || fail "final release ausente mesmo apos bootstrap: $FINAL_RELEASE"
[[ -f "$DEPLOY_PAYLOAD" ]] || fail "deploy payload ausente mesmo apos bootstrap: $DEPLOY_PAYLOAD"

run_step "bundle_validate" bash -c \
  "databricks bundle validate -t \"$ENV_NAME\" -p \"$PROFILE\" --var=\"deploy_user=${DEPLOY_USER}\" >\"$VALIDATE_LOG\" 2>&1"

run_step "bundle_deploy" bash -c \
  "databricks bundle deploy -t \"$ENV_NAME\" -p \"$PROFILE\" --var=\"deploy_user=${DEPLOY_USER}\" >\"$DEPLOY_LOG\" 2>&1"

python3 - <<PY
from pathlib import Path
import json
import yaml

env_name = "${ENV_NAME}"
final_release = yaml.safe_load(Path("${FINAL_RELEASE}").read_text(encoding="utf-8"))
payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

result = {
    "status": "apply_success",
    "env": env_name,
    "release_version": final_release["release_version"],
    "artifact_wheel": final_release["artifact_wheel"],
    "job_count": payload["job_count"],
    "mode": "databricks_official_cli",
    "run_dir": "${RUN_DIR}",
    "validate_log": "${VALIDATE_LOG}",
    "deploy_log": "${DEPLOY_LOG}",
    "trace_log": "${TRACE_LOG}",
    "result_json": "${RESULT_JSON}",
}

result_json = json.dumps(result, indent=2, ensure_ascii=False)
Path("${RESULT_JSON}").write_text(result_json + "\n", encoding="utf-8")
print(result_json)
PY
