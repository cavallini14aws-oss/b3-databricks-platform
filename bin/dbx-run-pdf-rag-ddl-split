#!/usr/bin/env bash
set -euo pipefail

: "${DBX_PROFILE:?DBX_PROFILE nao definido}"
: "${DATABRICKS_SQL_WAREHOUSE_ID:?DATABRICKS_SQL_WAREHOUSE_ID nao definido}"
TARGET_CATALOG="${TARGET_CATALOG:-workspace}"
TARGET_SCHEMA="${TARGET_SCHEMA:-pdf_rag}"

run_sql() {
  local sql="$1"
  databricks api post /api/2.0/sql/statements \
    --profile "$DBX_PROFILE" \
    --json "{
      \"warehouse_id\": \"$DATABRICKS_SQL_WAREHOUSE_ID\",
      \"statement\": $(python3 - <<PY
import json
sql = """$sql"""
print(json.dumps(sql))
PY
),
      \"wait_timeout\": \"50s\",
      \"on_wait_timeout\": \"CONTINUE\"
    }"
}

echo "[INFO] Creating schema ${TARGET_CATALOG}.${TARGET_SCHEMA}"
run_sql "CREATE SCHEMA IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}"

echo "[INFO] Creating pdf_documents"
run_sql "CREATE TABLE IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}.pdf_documents (
  document_id STRING,
  file_name STRING,
  display_name STRING,
  quality_tier STRING,
  extraction_strategy STRING,
  usable_pages INT,
  total_pages INT,
  avg_ocr_noise_score DOUBLE,
  ingestion_ts TIMESTAMP
) USING DELTA"

echo "[INFO] Creating pdf_pages"
run_sql "CREATE TABLE IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}.pdf_pages (
  document_id STRING,
  file_name STRING,
  page_number INT,
  page_text STRING,
  extraction_method STRING,
  page_quality_tier STRING,
  is_usable BOOLEAN,
  ingestion_ts TIMESTAMP
) USING DELTA"

echo "[INFO] Creating pdf_chunks"
run_sql "CREATE TABLE IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}.pdf_chunks (
  document_id STRING,
  file_name STRING,
  display_name STRING,
  chunk_id STRING,
  page_number INT,
  chunk_text STRING,
  chunk_text_normalized STRING,
  chunk_hash STRING,
  page_extraction_method STRING,
  document_quality_tier STRING,
  ingestion_ts TIMESTAMP
) USING DELTA"

echo "[INFO] Creating pdf_chunk_embeddings"
run_sql "CREATE TABLE IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}.pdf_chunk_embeddings (
  chunk_id STRING,
  document_id STRING,
  file_name STRING,
  embedding ARRAY<DOUBLE>,
  embedding_model STRING,
  embedding_ts TIMESTAMP
) USING DELTA"

echo "[INFO] Creating pdf_document_quality_reports"
run_sql "CREATE TABLE IF NOT EXISTS ${TARGET_CATALOG}.${TARGET_SCHEMA}.pdf_document_quality_reports (
  document_id STRING,
  file_name STRING,
  report_json STRING,
  quality_tier STRING,
  strategy_name STRING,
  report_ts TIMESTAMP
) USING DELTA"

echo "[INFO] Validating tables"
run_sql "SHOW TABLES IN ${TARGET_CATALOG}.${TARGET_SCHEMA}"
