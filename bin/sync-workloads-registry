#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

SRC="config/workloads_registry.yml"
DST="data_platform/resources/config/workloads_registry.yml"

if [[ ! -f "$SRC" ]]; then
  echo "[ERROR] Registry fonte ausente: $SRC"
  exit 1
fi

mkdir -p "$(dirname "$DST")"
cp "$SRC" "$DST"

echo "[OK] Workloads registry sincronizado"
echo "[INFO] src=$SRC"
echo "[INFO] dst=$DST"
