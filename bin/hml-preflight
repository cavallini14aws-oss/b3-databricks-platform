#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
fi

# shellcheck disable=SC1091
source bin/use-databricks-official-m2m hml

bin/check-runtime-env prd-m2m
bin/check-live-auth hml
bin/check-official-prod-readiness hml

echo "[OK] HML pronta para validação"
echo "[INFO] host=$DATABRICKS_HOST"
echo "[INFO] endpoint=$DATABRICKS_SERVING_ENDPOINT"
