#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/show-final-official-release <dev|hml|prd>"
  exit 1
fi

FILE=".state/releases/final-official-release-${ENV_NAME}.yml"

if [[ ! -f "$FILE" ]]; then
  echo "[ERROR] Final official release ausente: $FILE"
  exit 1
fi

cat "$FILE"
