#!/usr/bin/env bash
set -euo pipefail

TARGET="${1:-}"
PROFILE="${2:-}"
DEPLOY_USER="${3:-}"

if [[ -z "${TARGET}" || -z "${PROFILE}" || -z "${DEPLOY_USER}" ]]; then
  echo "uso: bin/dbx-bundle-validate <target> <profile> <deploy_user>"
  echo "exemplo: bin/dbx-bundle-validate dev DEFAULT user@example.com"
  exit 1
fi

databricks bundle validate -t "${TARGET}" -p "${PROFILE}" --var="deploy_user=${DEPLOY_USER}"
