#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
fi

# shellcheck disable=SC1091
source bin/use-databricks-official-m2m prd

bin/check-runtime-env prd-m2m
bin/check-prod-hardening prd
bin/check-official-prod-readiness prd

echo "[OK] produção pronta para deploy"
