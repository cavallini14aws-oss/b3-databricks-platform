#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

WORKLOAD_NAME="${1:-}"

if [[ -z "$WORKLOAD_NAME" ]]; then
  echo "[ERROR] Uso: bin/resolve-workload-profile <workload_name>"
  exit 1
fi

./bin/render-all-workload-manifests >/dev/null

MANIFEST_FILE=".state/workloads/${WORKLOAD_NAME}.yml"

if [[ ! -f "$MANIFEST_FILE" ]]; then
  echo "[ERROR] Workload manifest ausente: $MANIFEST_FILE"
  exit 1
fi

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import yaml

data = yaml.safe_load(Path("${MANIFEST_FILE}").read_text(encoding="utf-8"))
print(data["profile"])
PY
