#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PORT="${PDF_RAG_PORT:-8010}"
PIDS="$(lsof -ti tcp:${PORT} || true)"
if [[ -n "$PIDS" ]]; then
  echo "[INFO] Killing processes on port ${PORT}: $PIDS"
  kill -9 $PIDS
  sleep 1
fi

./bin/rebuild-and-restart-pdf-rag-lab &
SERVER_PID=$!

echo "[INFO] Waiting for health endpoint..."
for _ in {1..30}; do
  if curl -s --max-time 2 "http://127.0.0.1:${PORT}/health" >/dev/null; then
    echo "[INFO] API is up"
    ./bin/test-pdf-rag-suite
    exit 0
  fi
  sleep 1
done

echo "[ERROR] API did not become healthy in time"
kill -9 "${SERVER_PID}" || true
exit 1
