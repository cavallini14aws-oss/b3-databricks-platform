#!/usr/bin/env python3
import json
from pathlib import Path

path = Path("data_platform/resources/state/release_state.json")
if not path.exists():
    print("[BLOCK] release_state.json não encontrado")
    raise SystemExit(1)

data = json.loads(path.read_text(encoding="utf-8"))

for env in ("dev", "hml", "prd"):
    if env not in data:
        print(f"[BLOCK] ambiente ausente no release_state: {env}")
        raise SystemExit(1)

print("[ALLOW] release_state válido")
print(json.dumps(data, indent=2, ensure_ascii=False))
