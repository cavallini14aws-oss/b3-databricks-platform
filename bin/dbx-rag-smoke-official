#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f ".venv/bin/activate" ]]; then
  echo "[INFO] Activating project virtualenv: $ROOT_DIR/.venv"
  source .venv/bin/activate
fi

echo "[INFO] Databricks RAG official M2M smoke"

if [[ "${LLM_PROVIDER:-}" != "databricks" ]]; then
  echo "[ERROR] LLM_PROVIDER must be databricks"
  exit 1
fi

if [[ "${DATABRICKS_AUTH_TYPE:-}" != "oauth-m2m" ]]; then
  echo "[ERROR] DATABRICKS_AUTH_TYPE must be oauth-m2m"
  exit 1
fi

for key in DATABRICKS_HOST DATABRICKS_CLIENT_ID DATABRICKS_CLIENT_SECRET DATABRICKS_SERVING_ENDPOINT; do
  if [[ -z "${!key:-}" ]]; then
    echo "[ERROR] ${key} not set"
    exit 1
  fi
done

if [[ ! "$DATABRICKS_HOST" =~ ^https:// ]]; then
  echo "[ERROR] DATABRICKS_HOST must start with https://"
  exit 1
fi

echo "[INFO] env=${DATABRICKS_ENV:-unset}"
echo "[INFO] auth_type=$DATABRICKS_AUTH_TYPE"
echo "[INFO] host=$DATABRICKS_HOST"
echo "[INFO] endpoint=$DATABRICKS_SERVING_ENDPOINT"
echo "[INFO] provider=$LLM_PROVIDER"
echo "[INFO] client_id=[REDACTED]"
echo "[INFO] client_secret=[REDACTED]"

python -m pytest tests/test_pdf_rag_llm_service_databricks.py -q

echo "[INFO] Databricks official M2M smoke finished successfully"
