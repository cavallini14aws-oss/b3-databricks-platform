#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

MODE="${1:-auto}"

if [[ -f "/Users/brunocavallini/Unicorn.ia/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source /Users/brunocavallini/Unicorn.ia/.venv/bin/activate
fi

if [[ "$MODE" == "auto" ]]; then
  case "${DATABRICKS_ENV:-}" in
    hml)
      MODE="hml-m2m"
      ;;
    prd)
      MODE="prd-m2m"
      ;;
    *)
      if [[ -n "${DATABRICKS_CONFIG_PROFILE:-}" ]]; then
        MODE="dev"
      elif [[ "${DATABRICKS_AUTH_TYPE:-}" == "oauth-m2m" ]]; then
        MODE="prd-m2m"
      else
        MODE="dev"
      fi
      ;;
  esac
fi

case "$MODE" in
  dev)
    echo "[INFO] loading official env: dev"
    # shellcheck disable=SC1091
    source bin/use-databricks-official dev
    echo "[INFO] dispatching official smoke: dev"
    exec ./bin/dbx-rag-smoke-official-dev
    ;;
  hml|hml-m2m)
    echo "[INFO] loading official env: hml-m2m"
    # shellcheck disable=SC1091
    source bin/use-databricks-official-m2m hml
    echo "[INFO] dispatching official smoke: hml-m2m"
    exec ./bin/dbx-rag-smoke-official-hml-m2m
    ;;
  prd|prd-m2m|m2m)
    echo "[INFO] loading official env: prd-m2m"
    # shellcheck disable=SC1091
    source bin/use-databricks-official-m2m prd
    echo "[INFO] dispatching official smoke: prd-m2m"
    exec ./bin/dbx-rag-smoke-official-prd-m2m
    ;;
  *)
    echo "[ERROR] modo inválido para dbx-rag-smoke-official: $MODE"
    echo "[INFO] use: ./bin/dbx-rag-smoke-official [dev|hml-m2m|prd-m2m|auto]"
    exit 1
    ;;
esac
