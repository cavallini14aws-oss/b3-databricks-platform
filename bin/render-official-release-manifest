#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/render-official-release-manifest <dev|hml|prd>"
  exit 1
fi

case "$ENV_NAME" in
  dev|hml|prd) ;;
  *)
    echo "[ERROR] Ambiente invalido: $ENV_NAME"
    exit 1
    ;;
esac

mkdir -p .state/releases

if [[ -f ".venv-min/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import json
import yaml
from datetime import datetime, timezone

env_name = "${ENV_NAME}"
profiles = ["data", "api", "ml", "rag"]

latest_manifest = Path("manifests/latest-artifact.yml")
if not latest_manifest.exists():
    raise SystemExit("[ERROR] manifests/latest-artifact.yml ausente")

latest_data = yaml.safe_load(latest_manifest.read_text(encoding="utf-8"))
artifact_wheel = latest_data["artifact"]["wheel"]

entries = []
missing = []

for profile in profiles:
    target_file = Path(".state/databricks") / f"bundle-target-{env_name}-{profile}.yml"
    plan_file = Path(f".state/deploy-plan-{env_name}-{profile}.json")
    payload_file = Path(".state/official") / f"official-payload-{env_name}-{profile}.json"

    ready = target_file.exists() and plan_file.exists() and payload_file.exists()

    if not ready:
        missing.append(profile)

    entries.append(
        {
            "profile": profile,
            "ready": ready,
            "deploy_plan": str(plan_file),
            "official_payload": str(payload_file),
            "bundle_target": str(target_file),
        }
    )

manifest = {
    "generated_at_utc": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "env": env_name,
    "artifact_wheel": artifact_wheel,
    "profiles": entries,
    "ready": len(missing) == 0,
    "missing_profiles": missing,
    "mode": "official-release-manifest",
}

out_file = Path(".state/releases") / f"official-release-manifest-{env_name}.yml"
out_file.write_text(yaml.safe_dump(manifest, allow_unicode=True, sort_keys=False), encoding="utf-8")

print(f"[OK] Release manifest gerado: {out_file}")
print(yaml.safe_dump(manifest, allow_unicode=True, sort_keys=False))
PY
