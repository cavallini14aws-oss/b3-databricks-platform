#!/usr/bin/env python3
from pathlib import Path
import yaml

workflow_dir = Path(".github/workflows")
required_files = {
    "pr-gate.yml",
    "deploy-dev.yml",
    "deploy-hml.yml",
    "deploy-prd.yml",
}

missing = [f for f in required_files if not (workflow_dir / f).exists()]
if missing:
    print(f"[BLOCK] workflows ausentes: {missing}")
    raise SystemExit(1)

for file_path in sorted(workflow_dir.glob("*.yml")):
    try:
        with file_path.open("r", encoding="utf-8") as f:
            yaml.safe_load(f)
    except Exception as exc:
        print(f"[BLOCK] YAML inválido em {file_path}: {exc}")
        raise SystemExit(1)

print("[ALLOW] workflows GitHub válidos")
