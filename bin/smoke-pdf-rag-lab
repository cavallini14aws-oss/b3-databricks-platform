#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

echo "[INFO] Running PDF RAG Lab smoke checks"

required_files=(
  "pipelines/examples/pdf_rag_lab/backend/services/config.py"
  "pipelines/examples/pdf_rag_lab/backend/services/llm_service.py"
  "pipelines/examples/pdf_rag_lab/backend/.env.example"
  "docs/examples/pdf_rag_lab/OPERATIONS.md"
  "bin/run-pdf-rag-lab-local"
  "bin/test-pdf-rag-lab-api"
)

for file in "${required_files[@]}"; do
  if [[ -f "$file" ]]; then
    echo "[OK] Found: $file"
  else
    echo "[ERROR] Missing: $file"
    exit 1
  fi
done

echo "[INFO] Checking config defaults"
grep -n 'LLM_PROVIDER\|DEFAULT_LLM_MODEL' pipelines/examples/pdf_rag_lab/backend/services/config.py

echo "[INFO] Running test suite"
python -m pytest -q

echo "[INFO] Smoke checks finished successfully"
