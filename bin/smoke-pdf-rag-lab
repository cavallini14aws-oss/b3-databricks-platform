#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  echo "[INFO] Using already active virtualenv: $VIRTUAL_ENV"
elif [[ -f ".venv/bin/activate" ]]; then
  echo "[INFO] Activating project virtualenv: $ROOT_DIR/.venv"
  source .venv/bin/activate
else
  echo "[WARN] No virtualenv active and no local .venv found"
fi

echo "[INFO] Running PDF RAG Lab smoke checks"

required_files=(
  "pipelines/examples/pdf_rag_lab/backend/services/config.py"
  "pipelines/examples/pdf_rag_lab/backend/services/llm_service.py"
  "pipelines/examples/pdf_rag_lab/backend/.env.example"
  "docs/examples/pdf_rag_lab/OPERATIONS.md"
  "bin/run-pdf-rag-lab-local"
  "bin/test-pdf-rag-lab-api"
)

for file in "${required_files[@]}"; do
  if [[ -f "$file" ]]; then
    echo "[OK] Found: $file"
  else
    echo "[ERROR] Missing: $file"
    exit 1
  fi
done

echo "[INFO] Python runtime"
which python || true
python --version || true
python -c "import sys; print('[INFO] sys.executable=', sys.executable)"

echo "[INFO] Verifying fitz import before pytest"
python -c "import fitz; import sys; print('[OK] fitz importado por', sys.executable)"

echo "[INFO] Checking config defaults"
grep -n 'LLM_PROVIDER\|DEFAULT_LLM_MODEL' pipelines/examples/pdf_rag_lab/backend/services/config.py

echo "[INFO] Running test suite"
python -m pytest -q

echo "[INFO] Smoke checks finished successfully"
