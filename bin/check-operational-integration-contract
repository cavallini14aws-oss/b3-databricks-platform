#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

CONTRACT_FILE="config/official_operational_integration_contract.yml"

if [[ ! -f "$CONTRACT_FILE" ]]; then
  echo "[ERROR] contrato ausente: $CONTRACT_FILE"
  exit 1
fi

if [[ -f ".venv-min/bin/activate" ]]; then
  source .venv-min/bin/activate
elif [[ -f ".venv/bin/activate" ]]; then
  source .venv/bin/activate
fi

python - <<PY
from pathlib import Path
import sys
import yaml

data = yaml.safe_load(Path("${CONTRACT_FILE}").read_text(encoding="utf-8"))
errors = []

if data.get("mode") != "official-operational-integration-contract":
    errors.append("mode invalido ou ausente")

for section in ["apply", "smoke"]:
    block = data.get(section, {})
    for key in ["adapter_script", "required_inputs", "expected_outputs", "success_exit_code"]:
        if key not in block:
            errors.append(f"{section}.{key} ausente")

if "current_mode" not in data:
    errors.append("current_mode ausente")

if "future_mode" not in data:
    errors.append("future_mode ausente")

if errors:
    print("[ERROR] contrato operacional invalido")
    for err in errors:
        print(" - " + err)
    sys.exit(1)

print("[OK] contrato operacional valido")
PY
