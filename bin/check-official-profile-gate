#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="${1:-}"
PROFILE_NAME="${2:-}"

if [[ -z "$ENV_NAME" || -z "$PROFILE_NAME" ]]; then
  echo "[ERROR] Uso: bin/check-official-profile-gate <dev|hml|prd> <data|api|ml|rag>"
  exit 1
fi

case "$ENV_NAME" in
  dev|hml|prd) ;;
  *)
    echo "[ERROR] Ambiente invalido: $ENV_NAME"
    exit 1
    ;;
esac

case "$PROFILE_NAME" in
  data|api|ml|rag) ;;
  *)
    echo "[ERROR] Profile invalido: $PROFILE_NAME"
    exit 1
    ;;
esac

PLAN_FILE=".state/deploy-plan-${ENV_NAME}-${PROFILE_NAME}.json"

if [[ "$ENV_NAME" == "hml" || "$ENV_NAME" == "prd" ]]; then
  if [[ ! -f "$PLAN_FILE" ]]; then
    echo "[ERROR] ${ENV_NAME} exige plano de deploy com profile explicito: $PLAN_FILE"
    exit 1
  fi
fi

echo "[OK] Gate de profile validado para env=${ENV_NAME} profile=${PROFILE_NAME}"
