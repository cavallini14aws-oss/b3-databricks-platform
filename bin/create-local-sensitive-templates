#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

create_example() {
  local target="$1"
  local example="${target}.example"

  if [[ -f "$example" ]]; then
    echo "[INFO] example ja existe: $example"
    return
  fi

  {
    echo "# Template example gerado automaticamente"
    echo "# Nao inserir valores reais neste arquivo"
    echo "# Arquivo real correspondente: ${target}"
  } > "$example"

  echo "[OK] example criado: $example"
}

found_any=0

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  found_any=1
  create_example "$file"
done < <(
  find . -maxdepth 1 -type f \( -name ".env.*.local" -o -name ".secrets.*.local" -o -name ".secrets.*.oauth.local" \) \
  | sed 's#^\./##' \
  | sort
)

if [[ "$found_any" -eq 0 ]]; then
  echo "[INFO] nenhum arquivo local sensivel encontrado"
fi
