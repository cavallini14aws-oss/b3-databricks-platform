#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
PROFILE="${BUNDLE_PROFILE:-}"
DEPLOY_USER="${BUNDLE_DEPLOY_USER:-}"
SMOKE_JOB="${BUNDLE_SMOKE_JOB:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/smoke-official-release-adapter <dev|hml|prd>"
  exit 1
fi

if [[ -z "$PROFILE" ]]; then
  echo "[ERROR] BUNDLE_PROFILE nao definido"
  exit 1
fi

if [[ -z "$DEPLOY_USER" ]]; then
  echo "[ERROR] BUNDLE_DEPLOY_USER nao definido"
  exit 1
fi

case "$ENV_NAME" in
  dev|hml|prd) ;;
  *)
    echo "[ERROR] Ambiente invalido: $ENV_NAME"
    exit 1
    ;;
esac

if [[ "$ENV_NAME" == "hml" || "$ENV_NAME" == "prd" ]]; then
  if [[ -z "$SMOKE_JOB" ]]; then
    echo "[ERROR] BUNDLE_SMOKE_JOB e obrigatorio para $ENV_NAME"
    exit 1
  fi
fi

DEPLOY_PAYLOAD=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

mkdir -p .state/releases
mkdir -p .state/logs

RUN_TS="$(date -u +"%Y%m%dT%H%M%SZ")"
RUN_DIR=".state/logs/smoke_${ENV_NAME}_${RUN_TS}"
mkdir -p "$RUN_DIR"

SUMMARY_BEFORE_LOG="${RUN_DIR}/bundle_summary_before_force_pull.log"
SUMMARY_AFTER_LOG="${RUN_DIR}/bundle_summary_after_force_pull.log"
RUN_LOG="${RUN_DIR}/bundle_run.log"
TRACE_LOG="${RUN_DIR}/trace.log"
ASSERTIONS_JSON="${RUN_DIR}/smoke_assertions.json"
RESULT_JSON="${RUN_DIR}/result.json"

log() {
  printf '[INFO] %s\n' "$1" | tee -a "$TRACE_LOG"
}

fail() {
  printf '[ERROR] %s\n' "$1" | tee -a "$TRACE_LOG" >&2
  exit 1
}

run_step() {
  local step_name="$1"
  shift
  local start_ts end_ts duration

  start_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  log "START ${step_name}"

  if ! "$@"; then
    fail "Falha na etapa: ${step_name}"
  fi

  end_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  duration="$(python3 - <<PY
start = float("${start_ts}")
end = float("${end_ts}")
print(f"{end - start:.3f}s")
PY
)"
  log "END ${step_name} duration=${duration}"
}

log "run_dir=${RUN_DIR}"
log "env=${ENV_NAME}"
log "profile=${PROFILE}"
log "deploy_user=${DEPLOY_USER}"
log "smoke_job=${SMOKE_JOB:-<none>}"

run_step "bootstrap_official_release_state" ./bin/bootstrap-official-release-state "$ENV_NAME"
run_step "render_official_release_manifest" ./bin/render-official-release-manifest "$ENV_NAME"
run_step "apply_final_official_release" ./bin/apply-final-official-release "$ENV_NAME"
run_step "render_databricks_deploy_payload" ./bin/render-databricks-deploy-payload "$ENV_NAME"

[[ -f "$DEPLOY_PAYLOAD" ]] || fail "deploy payload ausente mesmo apos bootstrap: $DEPLOY_PAYLOAD"

run_step "bundle_summary_before_force_pull" bash -c \
  "databricks bundle summary -t \"$ENV_NAME\" -p \"$PROFILE\" --force-pull --var=\"deploy_user=${DEPLOY_USER}\" >\"$SUMMARY_BEFORE_LOG\" 2>&1"

RUN_STATUS="not_required"
if [[ -n "$SMOKE_JOB" ]]; then
  run_step "bundle_run_${SMOKE_JOB}" bash -c \
    "databricks bundle run -t \"$ENV_NAME\" -p \"$PROFILE\" --var=\"deploy_user=${DEPLOY_USER}\" \"$SMOKE_JOB\" >\"$RUN_LOG\" 2>&1"
  RUN_STATUS="executed"
fi

run_step "bundle_summary_after_force_pull" bash -c \
  "databricks bundle summary -t \"$ENV_NAME\" -p \"$PROFILE\" --force-pull --var=\"deploy_user=${DEPLOY_USER}\" >\"$SUMMARY_AFTER_LOG\" 2>&1"

python3 - <<PY
from pathlib import Path
from datetime import datetime, timezone
import json

env_name = "${ENV_NAME}"
profile = "${PROFILE}"
smoke_job = "${SMOKE_JOB}"
deploy_user = "${DEPLOY_USER}"
payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

assertions = {
    "env": env_name,
    "profile": profile,
    "deploy_user": deploy_user,
    "smoke_job_required": env_name in {"hml", "prd"},
    "smoke_job_present": bool(smoke_job),
    "smoke_job_status": "${RUN_STATUS}",
    "summary_before_force_pull_exists": Path("${SUMMARY_BEFORE_LOG}").exists(),
    "summary_after_force_pull_exists": Path("${SUMMARY_AFTER_LOG}").exists(),
    "run_log_exists": Path("${RUN_LOG}").exists(),
    "trace_log_exists": Path("${TRACE_LOG}").exists(),
    "payload_exists": Path("${DEPLOY_PAYLOAD}").exists(),
}

Path("${ASSERTIONS_JSON}").write_text(
    json.dumps(assertions, indent=2, ensure_ascii=False) + "\n",
    encoding="utf-8",
)

result = {
    "status": "smoke_success",
    "env": env_name,
    "profile": profile,
    "checked_at_utc": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "release_version": payload["deploy_version"],
    "job_count": payload["job_count"],
    "mode": "databricks_official_cli",
    "smoke_job_required": env_name in {"hml", "prd"},
    "smoke_job_status": "${RUN_STATUS}",
    "smoke_job_name": smoke_job,
    "run_dir": "${RUN_DIR}",
    "summary_before_force_pull_log": "${SUMMARY_BEFORE_LOG}",
    "summary_after_force_pull_log": "${SUMMARY_AFTER_LOG}",
    "run_log": "${RUN_LOG}",
    "trace_log": "${TRACE_LOG}",
    "assertions_json": "${ASSERTIONS_JSON}",
    "result_json": "${RESULT_JSON}",
}

result_json = json.dumps(result, indent=2, ensure_ascii=False)
Path("${RESULT_JSON}").write_text(result_json + "\n", encoding="utf-8")
print(result_json)
PY
