#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
PROFILE="${BUNDLE_PROFILE:-}"
DEPLOY_USER="${BUNDLE_DEPLOY_USER:-}"
SMOKE_JOB="${BUNDLE_SMOKE_JOB:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/smoke-official-release-adapter <dev|hml|prd>"
  exit 1
fi

if [[ -z "$PROFILE" ]]; then
  echo "[ERROR] BUNDLE_PROFILE nao definido"
  exit 1
fi

if [[ -z "$DEPLOY_USER" ]]; then
  echo "[ERROR] BUNDLE_DEPLOY_USER nao definido"
  exit 1
fi

DEPLOY_PAYLOAD=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

mkdir -p .state/releases
mkdir -p .state/logs

RUN_TS="$(date -u +"%Y%m%dT%H%M%SZ")"
RUN_DIR=".state/logs/smoke_${ENV_NAME}_${RUN_TS}"
mkdir -p "$RUN_DIR"

SUMMARY_LOG="${RUN_DIR}/bundle_summary.log"
RUN_LOG="${RUN_DIR}/bundle_run.log"
TRACE_LOG="${RUN_DIR}/trace.log"
RESULT_JSON="${RUN_DIR}/result.json"

log() {
  printf '[INFO] %s\n' "$1" | tee -a "$TRACE_LOG"
}

fail() {
  printf '[ERROR] %s\n' "$1" | tee -a "$TRACE_LOG" >&2
  exit 1
}

run_step() {
  local step_name="$1"
  shift
  local start_ts end_ts duration

  start_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  log "START ${step_name}"

  if ! "$@"; then
    fail "Falha na etapa: ${step_name}"
  fi

  end_ts="$(python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
)"
  duration="$(python3 - <<PY
start = float("${start_ts}")
end = float("${end_ts}")
print(f"{end - start:.3f}s")
PY
)"
  log "END ${step_name} duration=${duration}"
}

log "run_dir=${RUN_DIR}"
log "env=${ENV_NAME}"
log "profile=${PROFILE}"

run_step "bootstrap_official_release_state" ./bin/bootstrap-official-release-state "$ENV_NAME"
run_step "render_official_release_manifest" ./bin/render-official-release-manifest "$ENV_NAME"
run_step "apply_final_official_release" ./bin/apply-final-official-release "$ENV_NAME"
run_step "render_databricks_deploy_payload" ./bin/render-databricks-deploy-payload "$ENV_NAME"

[[ -f "$DEPLOY_PAYLOAD" ]] || fail "deploy payload ausente mesmo apos bootstrap: $DEPLOY_PAYLOAD"

run_step "bundle_summary" bash -c \
  "databricks bundle summary -t \"$ENV_NAME\" -p \"$PROFILE\" --var=\"deploy_user=${DEPLOY_USER}\" >\"$SUMMARY_LOG\" 2>&1"

RUN_STATUS="not_executed"
if [[ -n "$SMOKE_JOB" ]]; then
  run_step "bundle_run_${SMOKE_JOB}" bash -c \
    "databricks bundle run -t \"$ENV_NAME\" -p \"$PROFILE\" --var=\"deploy_user=${DEPLOY_USER}\" \"$SMOKE_JOB\" >\"$RUN_LOG\" 2>&1"
  RUN_STATUS="executed"
fi

python3 - <<PY
from pathlib import Path
from datetime import datetime, timezone
import json

env_name = "${ENV_NAME}"
payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

result = {
    "status": "smoke_success",
    "env": env_name,
    "checked_at_utc": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "release_version": payload["deploy_version"],
    "job_count": payload["job_count"],
    "mode": "databricks_official_cli",
    "smoke_job_status": "${RUN_STATUS}",
    "smoke_job_name": "${SMOKE_JOB}",
    "run_dir": "${RUN_DIR}",
    "summary_log": "${SUMMARY_LOG}",
    "run_log": "${RUN_LOG}",
    "trace_log": "${TRACE_LOG}",
    "result_json": "${RESULT_JSON}",
}

result_json = json.dumps(result, indent=2, ensure_ascii=False)
Path("${RESULT_JSON}").write_text(result_json + "\n", encoding="utf-8")
print(result_json)
PY
