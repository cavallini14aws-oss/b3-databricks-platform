#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

ENV_NAME="${1:-}"
PROFILE="${BUNDLE_PROFILE:-}"
DEPLOY_USER="${BUNDLE_DEPLOY_USER:-}"
SMOKE_JOB="${BUNDLE_SMOKE_JOB:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "[ERROR] Uso: bin/smoke-official-release-adapter <dev|hml|prd>"
  exit 1
fi

if [[ -z "$PROFILE" ]]; then
  echo "[ERROR] BUNDLE_PROFILE nao definido"
  exit 1
fi

if [[ -z "$DEPLOY_USER" ]]; then
  echo "[ERROR] BUNDLE_DEPLOY_USER nao definido"
  exit 1
fi

DEPLOY_PAYLOAD=".state/releases/databricks-deploy-payload-${ENV_NAME}.json"

mkdir -p .state/releases

./bin/bootstrap-official-release-state "$ENV_NAME"
./bin/render-official-release-manifest "$ENV_NAME" >/dev/null
./bin/apply-final-official-release "$ENV_NAME" >/dev/null
./bin/render-databricks-deploy-payload "$ENV_NAME" >/dev/null

if [[ ! -f "$DEPLOY_PAYLOAD" ]]; then
  echo "[ERROR] deploy payload ausente mesmo apos bootstrap: $DEPLOY_PAYLOAD"
  exit 1
fi

SUMMARY_LOG="$(mktemp)"
RUN_LOG="$(mktemp)"

cleanup() {
  rm -f "$SUMMARY_LOG" "$RUN_LOG"
}
trap cleanup EXIT

databricks bundle summary -t "$ENV_NAME" -p "$PROFILE" --var="deploy_user=${DEPLOY_USER}" >"$SUMMARY_LOG"

RUN_STATUS="not_executed"
if [[ -n "$SMOKE_JOB" ]]; then
  databricks bundle run -t "$ENV_NAME" -p "$PROFILE" --var="deploy_user=${DEPLOY_USER}" "$SMOKE_JOB" >"$RUN_LOG"
  RUN_STATUS="executed"
fi

python3 - <<PY
from pathlib import Path
from datetime import datetime, timezone
import json

env_name = "${ENV_NAME}"
payload = json.loads(Path("${DEPLOY_PAYLOAD}").read_text(encoding="utf-8"))

result = {
    "status": "smoke_success",
    "env": env_name,
    "checked_at_utc": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "release_version": payload["deploy_version"],
    "job_count": payload["job_count"],
    "mode": "databricks_official_cli",
    "smoke_job_status": "${RUN_STATUS}",
    "smoke_job_name": "${SMOKE_JOB}",
}

print(json.dumps(result, indent=2, ensure_ascii=False))
PY
